        "\"\"\"\n",
        "E-COMMERCE SALES ANALYSIS — MINI PROJECT\n",
        "-----------------------------------------\n",
        "Features: Best-selling products, monthly trends, customer patterns, revenue analysis\n",
        "Concepts: Data Cleaning, GroupBy, Sorting, Aggregation\n",
        "\"\"\"\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from datetime import datetime, timedelta\n",
        "\n",
        "\n",
        "# 1. GENERATE SAMPLE DATA (small, realistic)\n",
        "\n",
        "np.random.seed(7)\n",
        "\n",
        "products = ['Laptop', 'Phone', 'Headphones', 'Mouse', 'Keyboard', 'Monitor', 'Tablet', 'Charger']\n",
        "categories = ['Electronics']*8\n",
        "prices = [999, 699, 149, 29, 79, 349, 449, 19]\n",
        "\n",
        "records = []\n",
        "start = datetime(2024, 1, 1)\n",
        "\n",
        "for i in range(600):\n",
        "    idx = np.random.randint(0, 8)\n",
        "    qty = np.random.randint(1, 4)\n",
        "    day = np.random.randint(0, 545)  # ~18 months\n",
        "    d = start + timedelta(days=day)\n",
        "    total = prices[idx] * qty * np.random.choice([1.0, 0.9, 0.85], p=[0.8, 0.1, 0.1])\n",
        "    records.append({\n",
        "        'order_id': i+1,\n",
        "        'date': d,\n",
        "        'product': products[idx],\n",
        "        'category': categories[idx],\n",
        "        'quantity': qty,\n",
        "        'price': prices[idx],\n",
        "        'total': round(total, 2),\n",
        "        'customer': f'C{np.random.randint(100, 300)}',\n",
        "        'region': np.random.choice(['US', 'EU', 'APAC'], p=[0.4, 0.35, 0.25])\n",
        "    })\n",
        "\n",
        "df = pd.DataFrame(records)\n",
        "\n",
        "\n",
        "# 2. DATA CLEANING\n",
        "\n",
        "print(\"=\" * 50)\n",
        "print(\"DATA CLEANING\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "# Force some dirty data\n",
        "df.loc[3, 'total'] = np.nan\n",
        "df.loc[7, 'quantity'] = -1\n",
        "df.loc[10, 'price'] = np.nan\n",
        "\n",
        "print(f\"Rows before: {len(df)}\")\n",
        "print(f\"Missing values:\\n{df.isnull().sum()}\")\n",
        "\n",
        "# Fill missing total\n",
        "df['total'] = df['total'].fillna(df['price'] * df['quantity'])\n",
        "# Remove bad quantities\n",
        "df = df[df['quantity'] > 0]\n",
        "# Fill missing price with column median\n",
        "df['price'] = df['price'].fillna(df['price'].median())\n",
        "\n",
        "# Parse dates\n",
        "df['date'] = pd.to_datetime(df['date'])\n",
        "df['month'] = df['date'].dt.to_period('M')\n",
        "df['day_name'] = df['date'].dt.day_name()\n",
        "\n",
        "print(f\"Rows after: {len(df)}\\n\")\n",
        "\n",
        "\n",
        "# 3. BEST-SELLING PRODUCTS\n",
        "\n",
        "print(\"=\" * 50)\n",
        "print(\"BEST-SELLING PRODUCTS\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "by_qty = df.groupby('product')['quantity'].sum().sort_values(ascending=False)\n",
        "by_rev = df.groupby('product')['total'].sum().sort_values(ascending=False)\n",
        "\n",
        "print(\"\\nTop 5 by Quantity Sold:\")\n",
        "for p, q in by_qty.head(5).items():\n",
        "    print(f\"  {p:>12} → {q} units\")\n",
        "\n",
        "print(\"\\nTop 5 by Revenue Generated:\")\n",
        "for p, r in by_rev.head(5).items():\n",
        "    print(f\"  {p:>12} → ${r:>8.2f}\")\n",
        "\n",
        "\n",
        "# 4. MONTHLY SALES TRENDS\n",
        "#\\=\n",
        "print(\"\\n\" + \"=\" * 50)\n",
        "print(\"MONTHLY SALES TRENDS\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "monthly = df.groupby('month').agg(\n",
        "    orders=('order_id', 'nunique'),\n",
        "    revenue=('total', 'sum'),\n",
        "    avg_order=('total', 'mean')\n",
        ")\n",
        "\n",
        "print(\"\\nFirst 6 months:\")\n",
        "print(monthly.head(6).to_string())\n",
        "\n",
        "# 5. CUSTOMER PURCHASING PATTERNS\n",
        "\n",
        "print(\"\\n\" + \"=\" * 50)\n",
        "print(\"CUSTOMER PATTERNS\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "customers = df.groupby('customer').agg(\n",
        "    orders=('order_id', 'nunique'),\n",
        "    spent=('total', 'sum'),\n",
        "    avg_spent=('total', 'mean')\n",
        ").sort_values('spent', ascending=False)\n",
        "\n",
        "# Segment\n",
        "def segment(s):\n",
        "    if s > 3000: return 'Platinum'\n",
        "    if s > 1500: return 'Gold'\n",
        "    if s > 500:  return 'Silver'\n",
        "    return 'Bronze'\n",
        "\n",
        "customers['segment'] = customers['spent'].apply(segment)\n",
        "\n",
        "print(\"\\nTop 5 Customers:\")\n",
        "print(customers.head(5).to_string())\n",
        "\n",
        "print(\"\\nSegment Breakdown:\")\n",
        "for seg, cnt in customers['segment'].value_counts().items():\n",
        "    print(f\"  {seg:>8}: {cnt} customers\")\n",
        "\n",
        "# Day-of-week pattern\n",
        "print(\"\\nOrders by Day of Week:\")\n",
        "print(df.groupby('day_name').agg(\n",
        "    orders=('order_id', 'nunique'),\n",
        "    revenue=('total', 'sum')\n",
        ").reindex(['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday']).to_string())\n",
        "\n",
        "\n",
        "# 6. REVENUE ANALYSIS\n",
        "\n",
        "print(\"\\n\" + \"=\" * 50)\n",
        "print(\"REVENUE ANALYSIS\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "total_rev = df['total'].sum()\n",
        "total_ord = df['order_id'].nunique()\n",
        "unique_cust = df['customer'].nunique()\n",
        "\n",
        "print(f\"\\nTotal Revenue:     ${total_rev:>8,.2f}\")\n",
        "print(f\"Total Orders:       {total_ord:>5}\")\n",
        "print(f\"Unique Customers:   {unique_cust:>5}\")\n",
        "print(f\"Avg Order Value:   ${total_rev/total_ord:>8.2f}\")\n",
        "\n",
        "print(\"\\nRevenue by Region:\")\n",
        "print(df.groupby('region').agg(\n",
        "    revenue=('total', 'sum'),\n",
        "    orders=('order_id', 'nunique')\n",
        ").assign(share=lambda x: round(x['revenue']/total_rev*100, 1)).to_string())\n",
        "\n",
        "\n",
        "# 7. VISUALIZATION (2 simple plots)\n",
        "\n",
        "plt.figure(figsize=(12, 5))\n",
        "\n",
        "# Plot 1: Monthly revenue\n",
        "plt.subplot(1, 2, 1)\n",
        "monthly_idx = monthly.index.astype(str)\n",
        "plt.plot(monthly_idx, monthly['revenue'], marker='o', color='#2E86AB', linewidth=2)\n",
        "plt.xticks(rotation=45)\n",
        "plt.title('Monthly Revenue Trend')\n",
        "plt.ylabel('Revenue ($)')\n",
        "plt.grid(alpha=0.3)\n",
        "\n",
        "# Plot 2: Top products by revenue (horizontal bar)\n",
        "plt.subplot(1, 2, 2)\n",
        "top5 = by_rev.head(5)\n",
        "plt.barh(top5.index, top5.values, color=sns.color_palette('muted', 5) if 'sns' in dir() else plt.cm.Blues(np.linspace(0.4, 0.9, 5)))\n",
        "plt.title('Top 5 Products by Revenue')\n",
        "plt.xlabel('Revenue ($)')\n",
        "for i, v in enumerate(top5.values):\n",
        "    plt.text(v + 50, i, f'${v:,.0f}', va='center', fontsize=9)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
    }
